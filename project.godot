; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Final Frontier"
run/main_scene="uid://bo1bklnfyima7"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameRegistry="*res://core/objects/game_object_registry.gd"
GameClock="*res://core/simulation/sim_clock.gd"
SolarSystem="*res://core/simulation/solar_system_model.gd"
BodyTextures="*res://core/autoload/body_textures.gd"

[debug]

gdscript/warnings/narrowing_conversion=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/custom_image="uid://bk7i1ke6xm8vg"

[editor_plugins]

enabled=PackedStringArray()

[gui]

theme/default_font_antialiasing=2
theme/custom_font="uid://dvbnsgphdfvje"

[importer_defaults]

texture={
&"mipmaps/generate": true
}

